VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_API_BASE_URL=http://localhost:5001/api
# Backend URL that serves example assets from EXAMPLES_PATH
VITE_EXAMPLES_BASE_URL=http://localhost:5001/examples
# Comma-separated list of Google email addresses allowed admin access
VITE_ADMIN_EMAILS=admin1@example.com,admin2@example.com
# Local emulator repo root used by Vite aliasing. Set this to your own folder name.
VITE_EMULATOR_PATH=../path-to-openhw-studio-emulator

